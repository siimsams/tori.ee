---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import BotanicalSprites from '../components/BotanicalSprites.astro';
import type { Lang } from '../i18n';
import { t, HTML_LANG } from '../i18n';

interface Props {
  lang: Lang;
  page: 'index' | 'more_info';
  titleOverride?: string;
}

const { lang, page, titleOverride } = Astro.props;
const title = titleOverride ?? t(lang, 'title');
---

<!doctype html>
<html lang={HTML_LANG[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="A website for booking canoe and bow hunting experiences at tori matkakeskus."
    />
    <meta name="author" content="Siim Sams" />
    <meta
      name="keywords"
      content="kanuu, tori, vibu, saun, soomaa, pärnumaa, rahvuspark, matk, navesti, jõgi"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#2b3a2a" />
    <meta name="msapplication-TileColor" content="#f6f1e7" />
    <meta name="msapplication-TileImage" content="/mstile-144x144.png" />
    <meta name="theme-color" content="#f6f1e7" />

    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=marcellus:400|karla:300,400,500,700|ibm-plex-mono:400,500"
    />

    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-11274608498"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-11274608498');
    </script>
  </head>
  <body>
    <BotanicalSprites />
    <Nav lang={lang} page={page} />
    <slot />
    <script>
      import '../scripts/menu.ts';
    </script>
  </body>
</html>
