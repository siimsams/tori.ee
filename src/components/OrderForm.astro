---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const orLabels: Record<Lang, string> = {
  ee: 'Või helista otse:',
  en: 'Or give us a call:',
  ru: 'Или позвоните:',
};
---

<section id="order" class="order">
  <p class="tori-mono">{t(lang, 'orderTrip.title')}</p>
  <h2 class="tori-display order-title">{t(lang, 'orderTrip.title')}</h2>
  <p class="order-lead">
    {orLabels[lang]}
    <a class="phone-link" href="tel:+37251142533">{t(lang, 'contactUs.phone')}</a>
  </p>

  <form id="order-form" action="/mail.php" method="post">
    <div class="field">
      <label for="name">{t(lang, 'orderTrip.fullName')}</label>
      <input type="text" name="name" id="name" required />
    </div>
    <div class="field">
      <label for="email">{t(lang, 'orderTrip.email')}</label>
      <input type="email" name="email" id="email" required />
    </div>
    <div class="field">
      <label for="phone">{t(lang, 'orderTrip.contactPhone')}</label>
      <input type="tel" name="phone" id="phone" required />
    </div>
    <div class="field">
      <label for="message">{t(lang, 'orderTrip.orderDescription')}</label>
      <textarea name="message" id="message" rows="5" required></textarea>
    </div>
    <input id="hiddentoken" type="hidden" name="token" />
    <div id="recaptcha-container"></div>
    <button title="Send message" type="button" id="submit-btn" class="submit">
      {t(lang, 'orderTrip.sendOrder')}
    </button>
  </form>

  <div id="success" class="success hidden">
    <img src="/circle_green_checkmark.svg" alt="" width="96" height="96" loading="lazy" decoding="async" />
    <h2 class="tori-display">{t(lang, 'orderTrip.success')}</h2>
  </div>
  <p id="failure" class="failure hidden">{t(lang, 'orderTrip.failure')}</p>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('order-form');
    const success = document.getElementById('success');
    const failure = document.getElementById('failure');
    const hiddenToken = document.getElementById('hiddentoken');
    const submitBtn = document.getElementById('submit-btn');
    if (!form || !success || !failure || !hiddenToken || !submitBtn) return;

    const SITEKEY = '6Lf97qkaAAAAAEm2DF9a2gyaRilWaekl7Zu4_FlB';
    let widgetId = null;
    let pendingExecute = false;
    let recaptchaLoaded = false;

    function gtagReportConversion() {
      if (typeof gtag !== 'function') return;
      gtag('event', 'conversion', { send_to: 'AW-11274608498/ZAhyCN6O-soYEPK-k4Aq' });
    }

    window.onRecaptchaLoad = function () {
      widgetId = grecaptcha.render('recaptcha-container', {
        sitekey: SITEKEY,
        size: 'invisible',
        callback: onSubmit,
      });
      if (pendingExecute) {
        pendingExecute = false;
        grecaptcha.execute(widgetId);
      }
    };

    function loadRecaptcha() {
      if (recaptchaLoaded) return;
      recaptchaLoaded = true;
      const s = document.createElement('script');
      s.src = 'https://www.google.com/recaptcha/api.js?onload=onRecaptchaLoad&render=explicit';
      s.async = true;
      document.head.appendChild(s);
    }

    form.addEventListener('focusin', loadRecaptcha, { once: true });
    form.addEventListener('input', loadRecaptcha, { once: true });
    form.addEventListener('pointerdown', loadRecaptcha, { once: true });

    submitBtn.addEventListener('click', function (e) {
      if (!form.reportValidity()) return;
      if (widgetId !== null) {
        grecaptcha.execute(widgetId);
      } else {
        pendingExecute = true;
        loadRecaptcha();
      }
    });

    function onSubmit(token) {
      hiddenToken.value = token;
      fetch(form.action, { method: form.method, body: new FormData(form) })
        .then((r) => r.json())
        .then((data) => {
          if (data.success) {
            form.reset();
            success.classList.remove('hidden');
            form.classList.add('hidden');
            failure.classList.add('hidden');
            gtagReportConversion();
          } else {
            failure.classList.remove('hidden');
          }
          if (widgetId !== null) grecaptcha.reset(widgetId);
        })
        .catch(() => {
          failure.classList.remove('hidden');
          if (widgetId !== null) grecaptcha.reset(widgetId);
        });
    }
  })();
</script>

<style>
  .order {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 4vw, 3rem) 2rem;
    text-align: center;
  }

  .order-title {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    margin-top: 0.6rem;
  }

  .order-lead {
    max-width: 46ch;
    margin: 1rem auto 2.5rem;
    color: #4b4838;
    font-family: var(--font-display);
  }

  .phone-link {
    color: var(--color-copper);
    text-decoration: none;
    border-bottom: 1px solid var(--color-copper);
    padding-bottom: 1px;
  }

  #order-form {
    display: grid;
    gap: 1rem;
    text-align: left;
  }

  .field label {
    display: block;
    margin-bottom: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-moss-soft);
  }

  .field input,
  .field textarea {
    width: 100%;
    background: var(--color-bone-2);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    font: inherit;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-ink);
    transition: border-color 0.3s, background 0.3s;
  }

  .field textarea {
    resize: vertical;
    min-height: 6rem;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-copper);
    background: var(--color-bone);
  }

  .submit {
    margin-top: 1rem;
    padding: 1rem 2rem;
    background: var(--color-moss);
    color: var(--color-bone);
    border: none;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 1.05rem;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.3s, color 0.3s;
  }

  .submit:hover {
    background: var(--color-copper);
    color: var(--color-ink);
  }

  .success {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .success.hidden {
    display: none;
  }

  .success h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .failure {
    color: #a04628;
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
  }

  .failure.hidden {
    display: none;
  }
</style>
