---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div id="order" class="w-full">
  <h2 class="text-center text-4xl">{t(lang, 'orderTrip.title')}</h2>
  <form id="order-form" class="space-y-4" action="/mail.php" method="post">
    <div class="flex flex-col items-end">
      <label for="name" class="self-start">{t(lang, 'orderTrip.fullName')}</label>
      <input type="text" name="name" id="name" class="p-2 w-full border-[3px] border-black border-solid" required />
    </div>
    <div class="flex flex-col items-end">
      <label for="email" class="self-start">{t(lang, 'orderTrip.email')}</label>
      <input type="email" name="email" id="email" class="p-2 w-full border-[3px] border-black border-solid" required />
    </div>
    <div class="flex flex-col items-end">
      <label for="phone" class="self-start">{t(lang, 'orderTrip.contactPhone')}</label>
      <input type="tel" name="phone" id="phone" class="p-2 w-full border-[3px] border-black border-solid" required />
    </div>
    <div class="flex flex-col items-end">
      <label for="message" class="self-start">{t(lang, 'orderTrip.orderDescription')}</label>
      <textarea
        name="message"
        id="message"
        cols="30"
        rows="6"
        class="p-2 w-full border-[3px] border-black border-solid"
        required></textarea>
    </div>
    <input id="hiddentoken" type="hidden" name="token" />
    <button
      title="Send message"
      type="button"
      class="g-recaptcha w-full px-10 py-2 border-[3px] border-black border-solid"
      data-sitekey="6Lf97qkaAAAAAEm2DF9a2gyaRilWaekl7Zu4_FlB"
      data-callback="onSubmit"
      data-action="submit"
    >
      {t(lang, 'orderTrip.sendOrder')}
    </button>
  </form>
  <div id="success" class="h-[622px] flex flex-col justify-center items-center hidden">
    <img class="h-[400px] w-[400px]" src="/circle_green_checkmark.svg" alt="" />
    <h2 class="text-center text-4xl pt-4">{t(lang, 'orderTrip.success')}</h2>
  </div>
  <h2 id="failure" class="text-red-500 pt-3 text-center hidden">{t(lang, 'orderTrip.failure')}</h2>
</div>

<script is:inline async src="https://www.google.com/recaptcha/api.js"></script>
<script is:inline>
  (function () {
    const form = document.getElementById('order-form');
    const success = document.getElementById('success');
    const failure = document.getElementById('failure');
    const hiddenToken = document.getElementById('hiddentoken');
    if (!form || !success || !failure || !hiddenToken) return;

    function gtagReportConversion() {
      if (typeof gtag !== 'function') return;
      gtag('event', 'conversion', { send_to: 'AW-11274608498/ZAhyCN6O-soYEPK-k4Aq' });
    }

    window.onSubmit = function (token) {
      if (!form.reportValidity()) return;
      hiddenToken.value = token;
      fetch(form.action, { method: form.method, body: new FormData(form) })
        .then((r) => r.json())
        .then((data) => {
          if (data.success) {
            form.reset();
            success.classList.remove('hidden');
            form.classList.add('hidden');
            failure.classList.add('hidden');
            gtagReportConversion();
          } else {
            failure.classList.remove('hidden');
          }
        })
        .catch(() => failure.classList.remove('hidden'));
    };
  })();
</script>
