---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const coords = '58.4815°N · 24.8109°E';
---

<section id="location" class="location">
  <p class="tori-mono">{coords}</p>
  <h2 class="tori-display location-title">{t(lang, 'menu.location')}</h2>
  <div class="map-frame">
    <iframe
      title="Tori Matkakeskus location on Google Map"
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d8343.075522572108!2d24.810938771713452!3d58.481500348077596!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x46ece6573013f239%3A0xd97fc28347415a84!2sTori%20Matkakeskus!5e0!3m2!1sen!2see!4v1688407668603!5m2!1sen!2see"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>

<style>
  .location {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
    text-align: center;
  }

  .location-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.6rem auto 2rem;
  }

  .map-frame {
    border: 1px solid var(--color-rule);
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-bone-2);
  }

  .map-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    filter: saturate(0.85) contrast(0.98);
  }
</style>
