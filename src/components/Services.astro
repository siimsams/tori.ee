---
import { Picture } from 'astro:assets';
import type { Lang } from '../i18n';
import { t, langPath } from '../i18n';
import kanuu from '../assets/kanuu-blur-grain.jpg';
import vibu from '../assets/vibu-blur-grain.jpg';
import saun from '../assets/saun-blur-grain.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const moreInfoHref = langPath(lang, 'more_info');

const readMore: Record<Lang, string> = {
  ee: 'Loe rohkem',
  en: 'Read more',
  ru: 'Подробнее',
};

const pillars = [
  {
    id: 'canoe',
    num: '№ 1',
    title: t(lang, 'canoeTrips.title'),
    body: t(lang, 'canoeTrips.description'),
    image: kanuu,
    alt: 'Canoe trip near Tori Põrgu',
    reversed: false,
  },
  {
    id: 'bow-hunting',
    num: '№ 2',
    title: t(lang, 'bowHunting.title'),
    body: t(lang, 'bowHunting.description'),
    image: vibu,
    alt: 'Bow hunting',
    reversed: true,
  },
  {
    id: 'sauna',
    num: '№ 3',
    title: t(lang, 'sauna.title'),
    body: t(lang, 'sauna.description'),
    image: saun,
    alt: 'Hot tub sauna',
    reversed: false,
  },
];
---

<section class="pillars">
  {pillars.map((p) => (
    <article class={`pillar ${p.reversed ? 'rev' : ''}`} id={p.id}>
      <div class="copy">
        <span class="num">{p.num}</span>
        <h3 class="tori-display pillar-title">{p.title}</h3>
        <p class="pillar-body">{p.body}</p>
        <a class="pillar-more" href={moreInfoHref}>
          {readMore[lang]} <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="media">
        <Picture
          src={p.image}
          formats={['avif', 'webp']}
          alt={p.alt}
          pictureAttributes={{ class: 'pillar-picture' }}
          class="pillar-img"
        />
      </div>
    </article>
  ))}
</section>

<style>
  .pillars {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3rem);
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .pillar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 800px) {
    .pillar {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .pillar.rev .copy {
      order: 2;
    }
    .pillar.rev .media {
      order: 1;
    }
  }

  .media {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 5 / 6;
    border: 1px solid var(--color-rule);
  }

  .media :global(.pillar-picture),
  .media :global(.pillar-img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }

  .num {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-copper);
    font-size: 1.8rem;
    display: inline-block;
  }

  .pillar-title {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    margin-top: 0.4rem;
    line-height: 1;
  }

  .pillar-body {
    margin-top: 1.2rem;
    max-width: 46ch;
    color: #3f3c2f;
  }

  .pillar-more {
    display: inline-block;
    margin-top: 1.4rem;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--color-copper);
    text-decoration: none;
    color: var(--color-copper);
    padding-bottom: 2px;
    transition: color 0.3s, border-color 0.3s;
  }

  .pillar-more:hover {
    color: var(--color-moss);
    border-color: var(--color-moss);
  }
</style>
