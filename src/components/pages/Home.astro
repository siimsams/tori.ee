---
import Layout from '../../layouts/Layout.astro';
import Header from '../Header.astro';
import Reviews from '../Reviews.astro';
import Services from '../Services.astro';
import Prices from '../Prices.astro';
import OrderForm from '../OrderForm.astro';
import Contact from '../Contact.astro';
import LocationMap from '../LocationMap.astro';
import Divider from '../Divider.astro';
import Signature from '../Signature.astro';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Layout lang={lang} page="index">
  <Header lang={lang} />
  <Divider leaf="sprig" />
  <Services lang={lang} />
  <Divider leaf="fern" />
  <Prices lang={lang} />
  <Divider leaf="willow" />
  <Reviews lang={lang} />
  <Divider leaf="sprig" />
  <OrderForm lang={lang} />
  <Contact lang={lang} />
  <Divider leaf="fern" />
  <LocationMap lang={lang} />
  <Signature lang={lang} />
</Layout>
