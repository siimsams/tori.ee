---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<header class="h-[85vh] grid items-center relative text-white">
  <div class="3xl:w-[1950px] 3xl:mx-auto xl:pl-36 pl-6 z-0">
    <h1 class="lg:text-7xl text-5xl break-all font-sans font-bold" set:html={t(lang, 'header.title')} />
    <p class="pt-3 pb-8 max-w-[520px]">{t(lang, 'header.subtitle')}</p>
    <a href="#order" class="px-10 py-3 border-[3px] border-white border-solid">{t(lang, 'menu.order')}</a>
  </div>
  <video
    id="myVideo"
    autoplay
    muted
    loop
    playsinline
    poster="/media/hero_video.jpg"
    class="h-full w-full object-cover max-w-none brightness-[0.75] -z-10 absolute top-0 left-0"
  >
    <source src="/media/hero_video.webm" type="video/webm" />
    <source src="/media/hero_video.mp4" type="video/mp4" />
  </video>
</header>
