---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="colophon">
  <p class="signature">{t(lang, 'contactUs.name')}, Tori Matkakeskus</p>
  <p class="tori-mono">© {new Date().getFullYear()} · Aastast 1996</p>
</footer>

<style>
  .colophon {
    text-align: center;
    padding: 3rem 1.5rem 4rem;
    border-top: 1px solid var(--color-rule);
    margin-top: 2rem;
  }

  .signature {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-moss-soft);
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
  }
</style>
