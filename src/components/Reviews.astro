---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="flex justify-center flex-col py-8 overflow-hidden text-center">
  <h2 class="pb-10 text-4xl">{t(lang, 'reviews')}</h2>
  <div class="flex items-center justify-center">
    <ul class="flex overflow-x-auto">
      <li class="flex flex-col items-center flex-shrink-0 px-7">
        <a
          target="_blank"
          rel="noopener"
          href="https://www.google.com/maps/place/Tori+Matkakeskus/@58.4815636,24.8108362,17z/data=!4m8!3m7!1s0x46ece6573013f239:0xd97fc28347415a84!8m2!3d58.4815636!4d24.8108362!9m1!1b1!16s%2Fg%2F11c2jw2vr1?entry=ttu"
        >
          <img class="h-[100px] w-[100px] object-contain mx-auto" src="/Google_logo.png" alt="Google Logo" />
          <p>Google</p>
        </a>
      </li>
      <li class="flex flex-col items-center flex-shrink-0 px-7">
        <a target="_blank" rel="noopener" href="https://www.facebook.com/torimatkakeskus">
          <img class="h-[100px] w-[100px] object-contain mx-auto" src="/facebook_logo.svg" alt="Facebook Logo" />
          <p>Facebook</p>
        </a>
      </li>
      <li class="flex flex-col items-center flex-shrink-0 px-7">
        <a
          target="_blank"
          rel="noopener"
          href="https://www.tripadvisor.com/Attraction_Review-g3296605-d26436166-Reviews-Tori_Adventure_Center-Tori_Parnu_County.html"
        >
          <img class="h-[100px] w-[100px] object-contain mx-auto" src="/tripadvisor-logo.svg" alt="Tripadvisor Logo" />
          <p>Tripadvisor</p>
        </a>
      </li>
    </ul>
  </div>
</section>
